const accentColors = {
  greetings: "#F0997B",
  introductions: "#EF9F27",
  airport: "#AFA9EC",
  checkin: "#5DCAA5",
  phrases: "#85B7EB"
};

const zhColors = {
  greetings: "#F0997B",
  introductions: "#EF9F27",
  airport: "#7A74E0",
  checkin: "#3DB88C",
  phrases: "#5E9FD8"
};

let currentFilter = "all";
let searchQuery = "";

function buildCards() {
  const grid = document.getElementById("cardGrid");
  const footer = document.getElementById("footer");

  const filtered = cards.filter(c => {
    const matchCat = currentFilter === "all" || c.cat === currentFilter;
    const q = searchQuery.toLowerCase();
    const matchSearch = !q || c.en.toLowerCase().includes(q) || c.zh.includes(q);
    return matchCat && matchSearch;
  });

  grid.innerHTML = filtered.length === 0
    ? '<div class="no-results">No words found. Try a different search! 🔍</div>'
    : filtered.map(c => `
      <div class="vcard" data-group="${c.cat}" data-en="${c.en}" data-zh="${c.zh}">
        <div class="vcard-accent" style="background:${accentColors[c.cat]}"></div>
        <div class="vcard-body">
          <div class="vcard-pic">${c.svg}</div>
          <div class="vcard-en">${c.en}</div>
          <div class="vcard-pron">${c.pron}</div>
          <div class="vcard-meaning">${c.meaning}</div>
          <div class="vcard-divider"></div>
          <div class="vcard-zh" style="color:${zhColors[c.cat]}">${c.zh}</div>
          <div class="vcard-ex">${c.ex1}</div>
          <div class="vcard-ex">${c.ex2}</div>
          <div class="vcard-practice">
            <div class="vcard-practice-label">✏ Try using this word:</div>
            <div class="vcard-practice-item">1. ${c.p1}</div>
            <div class="vcard-practice-item">2. ${c.p2}</div>
          </div>
        </div>
      </div>`).join("");

  footer.textContent = `Showing ${filtered.length} of ${cards.length} words`;
}

document.querySelectorAll(".filter-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".filter-btn").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
    currentFilter = btn.dataset.cat;
    buildCards();
  });
});

document.getElementById("searchInput").addEventListener("input", e => {
  searchQuery = e.target.value;
  buildCards();
});

buildCards();
</script>
